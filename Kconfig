config ZMK_ANALOG_STICK
	bool "ZMK Analog Stick Driver"
	default y
	depends on DT_HAS_ZMK_ANALOG_STICK_ENABLED
	select ADC
	select GPIO
	select INPUT
	select ZMK_POINTING
	help
	  Multi-mode analog stick driver for ZMK. Reads analog position
	  sensors (TMR, hall-effect, etc.) via io-channels (MCP3208,
	  nRF52840 SAADC, etc.) and emits Zephyr input events. Supports
	  switch, mouse pointer, and scroll modes switchable per keymap
	  layer.

config ZMK_ANALOG_STICK_STICK_COUNT
	int "Maximum number of analog stick instances"
	default 1
	range 1 8
	depends on ZMK_ANALOG_STICK
	help
	  Maximum number of analog stick instances supported. Used to
	  size the scan coordinator's instance registry at compile time.
	  Set to match the number of zmk,analog-stick nodes in your DTS.

config ZMK_ANALOG_STICK_WORK_QUEUE_STACK_SIZE
	int "Analog stick work queue stack size"
	default 3072
	range 1024 8192
	depends on ZMK_ANALOG_STICK
	help
	  Stack size for the dedicated analog stick work queue thread.
	  Default 3072 is sufficient for 8-stick configurations
	  with logging enabled, providing margin for ISR preemption.

config ZMK_ANALOG_STICK_BLE_POLL_FLOOR
	int "BLE poll floor (ms)"
	default 8
	range 1 100
	depends on ZMK_ANALOG_STICK
	help
	  Minimum active poll interval when BLE is enabled. Polling faster
	  than the BLE connection interval wastes power without improving
	  responsiveness. The scan coordinator may raise this floor
	  dynamically based on the negotiated BLE connection interval.

config ZMK_ANALOG_STICK_CI_FLOOR_OVERRIDE
	int "CI floor override (ms)"
	default 0
	range 0 1000
	depends on ZMK_ANALOG_STICK
	help
	  When nonzero, overrides the BLE connection-interval-derived
	  poll floor with this fixed value. Useful for testing or forcing
	  a specific poll rate regardless of the negotiated CI.
	  Set to 0 (default) to use dynamic CI tracking.

config ZMK_ANALOG_STICK_ACTIVE_COOLDOWN_MS
	int "Active poll cooldown (ms)"
	default 250
	range 0 5000
	depends on ZMK_ANALOG_STICK
	help
	  After the stick returns to center, keep polling at the active
	  rate for this many milliseconds before dropping to idle. This
	  ensures rapid successive flicks (e.g. double-tap a direction)
	  are not missed due to the slow idle poll interval.
	  Set to 0 to disable (immediately return to idle polling).

config ZMK_ANALOG_STICK_INIT_PRIORITY
	int "Analog stick init priority"
	default 90
	depends on ZMK_ANALOG_STICK
	help
	  Initialization priority for analog stick devices. Must be after
	  ADC and GPIO device init (POST_KERNEL).

config ZMK_ANALOG_STICK_AUTO_CENTER
	bool "Auto-center calibration at boot"
	default n
	depends on ZMK_ANALOG_STICK
	help
	  Sample the ADC at boot (while the stick is at rest) and use the
	  average as the center point, overriding the devicetree x-center /
	  y-center values. The stick must be centered when the keyboard
	  powers on.

config ZMK_ANALOG_STICK_AUTO_CENTER_SAMPLES
	int "Number of samples for auto-center averaging"
	default 16
	range 4 256
	depends on ZMK_ANALOG_STICK_AUTO_CENTER
	help
	  Number of ADC samples to average when measuring the center point
	  at boot. More samples reduce noise but increase init time.
	  16 samples at ~40us each adds ~640us to boot.

config ZMK_ANALOG_STICK_HID_FLUSH_PER_STICK
	bool "Flush HID report after each stick (no coordinator)"
	default y if !ZMK_SPLIT || ZMK_SPLIT_ROLE_CENTRAL
	default n
	depends on ZMK_ANALOG_STICK
	help
	  When enabled, the input listener flushes the HID accumulator
	  immediately after each stick's mouse/scroll contribution.
	  Enable this for central-side or non-split configurations where
	  the scan coordinator is not calling flush. On peripheral side
	  with scan coordinator, leave disabled (coordinator flushes).

module = ZMK_ANALOG_STICK
module-str = zmk_analog_stick
source "subsys/logging/Kconfig.template.log_config"
